      "id": 3,
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(teamos_http_request_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "{{service_name}}", "refId": "A"}],
      "title": "HTTP p95",
      "type": "timeseries"
    },
