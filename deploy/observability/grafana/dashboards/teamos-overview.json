      "options": {"legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [{"expr": "sum by (service_name) (rate(teamos_http_requests_total[$__rate_interval]))", "legendFormat": "{{service_name}}", "refId": "A"}],
      "title": "HTTP-запросы",
