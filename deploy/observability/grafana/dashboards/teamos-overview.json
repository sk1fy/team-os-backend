    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "id": 2,
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [{"expr": "sum by (service_name) (rate(teamos_http_requests_total{status=~\"5..\"}[$__rate_interval])) / clamp_min(sum by (service_name) (rate(teamos_http_requests_total[$__rate_interval])), 0.001)", "legendFormat": "{{service_name}}", "refId": "A"}],
      "title": "Доля ответов 5xx",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
